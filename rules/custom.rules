##############################################################################
# ICMP
##############################################################################

alert icmp any any -> any any (msg:"ICMP Ping Detected"; sid:1000001; rev:1;)

alert icmp any any -> any any (msg:"ICMP Flood Possible"; detection_filter:track by_src,count 20,seconds 1; sid:1000002; rev:1;)

##############################################################################
# NMAP / PORT SCAN
##############################################################################

alert tcp any any -> $HOME_NET any (msg:"TCP Port Scan"; flags:S; detection_filter:track by_src,count 15,seconds 5; sid:1000010; rev:1;)

alert udp any any -> $HOME_NET any (msg:"UDP Port Scan"; detection_filter:track by_src,count 20,seconds 5; sid:1000011; rev:1;)

alert ip any any -> $HOME_NET any (msg:"Host Discovery Scan"; detection_filter:track by_src,count 10,seconds 3; sid:1000012; rev:1;)

##############################################################################
# SSH
##############################################################################

alert tcp any any -> $HOME_NET 22 (msg:"SSH Connection Attempt"; sid:1000020; rev:1;)

drop tcp any any -> $HOME_NET 22 (msg:"SSH Brute Force Blocked"; flow:to_server; detection_filter:track by_src,count 5,seconds 60; sid:1000021; rev:1;)

##############################################################################
# FTP
##############################################################################

alert tcp any any -> $HOME_NET 21 (msg:"FTP Login Attempt"; content:"USER"; nocase; sid:1000030; rev:1;)

drop tcp any any -> $HOME_NET 21 (msg:"FTP Brute Force Blocked"; content:"USER"; nocase; detection_filter:track by_src,count 5,seconds 60; sid:1000031; rev:1;)

##############################################################################
# TELNET
##############################################################################

drop tcp any any -> $HOME_NET 23 (msg:"Telnet Brute Force"; detection_filter:track by_src,count 5,seconds 60; sid:1000040; rev:1;)

##############################################################################
# SQL Injection
##############################################################################

alert tcp any any -> $HOME_NET 80 (msg:"SQL Injection OR 1=1"; content:"or 1=1"; nocase; sid:1000050; rev:1;)

alert tcp any any -> $HOME_NET 80 (msg:"SQL Injection UNION SELECT"; content:"union select"; nocase; sid:1000051; rev:1;)

alert tcp any any -> $HOME_NET 80 (msg:"SQL Injection DROP TABLE"; content:"drop table"; nocase; sid:1000052; rev:1;)

alert tcp any any -> $HOME_NET 80 (msg:"SQL Injection INFORMATION_SCHEMA"; content:"information_schema"; nocase; sid:1000053; rev:1;)

##############################################################################
# Command Injection
##############################################################################

alert tcp any any -> $HOME_NET 80 (msg:"Command Injection ;"; content:";"; sid:1000060; rev:1;)

alert tcp any any -> $HOME_NET 80 (msg:"Command Injection &&"; content:"&&"; sid:1000061; rev:1;)

alert tcp any any -> $HOME_NET 80 (msg:"Command Injection |"; content:"|"; sid:1000062; rev:1;)

##############################################################################
# Reverse Shell
##############################################################################

alert tcp $HOME_NET any -> any 4444 (msg:"Reverse Shell Port 4444"; sid:1000070; rev:1;)

alert tcp $HOME_NET any -> any 5555 (msg:"Reverse Shell Port 5555"; sid:1000071; rev:1;)

alert tcp any any -> any any (msg:"Possible Bash Reverse Shell"; content:"/bin/bash"; nocase; sid:1000072; rev:1;)

alert tcp any any -> any any (msg:"Possible Netcat Reverse Shell"; content:"nc -e"; nocase; sid:1000073; rev:1;)

##############################################################################
# Malware Beacon
##############################################################################

alert tcp $HOME_NET any -> any any (msg:"Possible Malware Beacon"; detection_filter:track by_src,count 30,seconds 60; sid:1000080; rev:1;)

##############################################################################
# Suspicious Downloads
##############################################################################

alert tcp any any -> $HOME_NET any (msg:"EXE Download"; file_data; content:".exe"; nocase; sid:1000090; rev:1;)

alert tcp any any -> $HOME_NET any (msg:"DLL Download"; file_data; content:".dll"; nocase; sid:1000091; rev:1;)

alert tcp any any -> $HOME_NET any (msg:"ZIP Download"; file_data; content:".zip"; nocase; sid:1000092; rev:1;)

alert tcp any any -> $HOME_NET any (msg:"PowerShell Script"; file_data; content:"powershell"; nocase; sid:1000093; rev:1;)

##############################################################################
# Web Shell
##############################################################################

alert tcp any any -> $HOME_NET 80 (msg:"PHP Web Shell"; content:"cmd="; nocase; sid:1000100; rev:1;)

alert tcp any any -> $HOME_NET 80 (msg:"PHP Web Shell"; content:"system("; nocase; sid:1000101; rev:1;)

##############################################################################
# DNS Tunneling
##############################################################################

alert udp any any -> any 53 (msg:"Possible DNS Tunnel"; detection_filter:track by_src,count 50,seconds 10; sid:1000110; rev:1;)

##############################################################################
# SMB
##############################################################################

alert tcp any any -> $HOME_NET 445 (msg:"SMB Connection"; sid:1000120; rev:1;)

##############################################################################
# RDP
##############################################################################

alert tcp any any -> $HOME_NET 3389 (msg:"RDP Connection"; sid:1000130; rev:1;)

##############################################################################
# HTTP Brute Force
##############################################################################

drop tcp any any -> $HOME_NET 80 (msg:"HTTP Login Brute Force"; content:"login"; nocase; detection_filter:track by_src,count 5,seconds 60; sid:1000140; rev:1;)
